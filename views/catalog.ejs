<%- include('partials/head') %>
<%- include('partials/header') %>
<main>
  <div class="container">
    <h1 style="font-size:26px">Каталог</h1>
    <form method="get" action="/catalog" class="card" style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end">
      <div style="flex:1;min-width:140px">
        <label>Жанр</label>
        <select class="field" name="genre">
          <option value="">Любой</option>
          <% genreList.forEach(function(g){ %><option value="<%= g.id %>" <%= String(filters.genre)===String(g.id)?'selected':'' %>><%= g.name %></option><% }) %>
        </select>
      </div>
      <div style="width:110px"><label>Год</label><input class="field" type="number" name="year" min="1900" max="2030" value="<%= filters.year||'' %>"/></div>
      <div style="width:90px"><label>Страна</label><input class="field" name="country" placeholder="US, RU…" value="<%= filters.country||'' %>"/></div>
      <div style="width:120px"><label>Рейтинг ≥</label><input class="field" type="number" step="0.5" min="0" max="10" name="rating" value="<%= filters.rating||'' %>"/></div>
      <div style="width:160px">
        <label>Сортировка</label>
        <select class="field" name="sort">
          <option value="popularity.desc" <%= filters.sort==='popularity.desc'?'selected':'' %>>Популярность</option>
          <option value="vote_average.desc" <%= filters.sort==='vote_average.desc'?'selected':'' %>>Рейтинг</option>
          <option value="primary_release_date.desc" <%= filters.sort==='primary_release_date.desc'?'selected':'' %>>Новизна</option>
        </select>
      </div>
      <button class="btn btn-sm">Показать</button>
    </form>

    <% if (!results.length) { %><p class="muted">Ничего не найдено. Измените фильтры.</p><% } %>
    <div class="grid" style="margin-top:18px">
      <% results.forEach(function(m){ %>
        <%- include('partials/filmcard', { card: { id: m.id, title: m.title, poster: tmdb.poster(m.poster_path), year: m.release_date?m.release_date.slice(0,4):null, rating: m.vote_average } }) %>
      <% }) %>
    </div>

    <% if (results.length) { %>
      <div class="center" style="margin-top:24px">
        <a class="btn btn-ghost btn-sm" href="/catalog?<%= new URLSearchParams(Object.assign({}, filters, {page: page+1})).toString() %>">Дальше →</a>
      </div>
    <% } %>
  </div>
</main>
<%- include('partials/footer') %>
